         url : '<?php echo $this->url('api/job', array(), array("query" => array("filter" => "last24h"))); ?>',
         dataType: 'json',
         timeout: function() {
            console.log('getJobsPast24h(): timeout');
         },
         success: function(data) {
            $('.waiting-jobs-field').empty();
            $('.waiting-jobs-field').append(
