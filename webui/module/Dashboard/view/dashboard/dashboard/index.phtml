            );
            $('.successful-jobs-field').empty();
            $('.successful-jobs-field').append(
               data.successful
            );
            $('.warning-jobs-field').empty();
            $('.warning-jobs-field').append(
               data.warning
            );
            $('.failed-jobs-field').empty();
            $('.failed-jobs-field').append(
               data.failed
            );
         },
         error: function() {
            console.log('getJobsPast24h(): error');
         },
         parseerror: function() {
