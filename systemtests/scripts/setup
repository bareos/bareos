#!/bin/bash
set -e
explicit_sql_ddl_dir="${SQL_DDL_DIR+set}"

. "${BAREOS_SCRIPTS_DIR}/functions"

print_debug "drop database \"${db_name}\""
"${BAREOS_SCRIPTS_DIR}/drop_bareos_database" 2>&1 >/dev/null \
  || echo "info: ${BAREOS_SCRIPTS_DIR}/drop_bareos_database failed"

print_debug "creating database \"${db_name}\""
"${BAREOS_SCRIPTS_DIR}/create_bareos_database" 2>&1 >/dev/null

if [ "${DBTYPE}" = "postgresql" ] && [ -z "${explicit_sql_ddl_dir}" ]; then
  print_debug \
    "skipping manual table creation for \"${db_name}\"; bareos-dir bootstraps the catalog contents"
else
  print_debug "making tables  \"${db_name}\""
  "${BAREOS_SCRIPTS_DIR}/make_bareos_tables" 2>&1 >/dev/null
fi

print_debug "granting privileges database \"${db_name}\""
"${BAREOS_SCRIPTS_DIR}/grant_bareos_privileges" 2>&1 >/dev/null \
  || echo "info: ${BAREOS_SCRIPTS_DIR}/grant_bareos_privileges failed"

if lsof="$(command -v lsof)"; then
  for port in $BASEPORT $BAREOS_DIRECTOR_PORT $BAREOS_STORAGE_PORT \
    $BAREOS_STORAGE2_PORT $BAREOS_FD_PORT $MINIO_PORT; do
    if pid=$("${lsof}" -ti "tcp:$port"); then
      print_debug "Killing process listening on $port with PID $pid"
      kill -9 "$pid"
    fi
  done
fi
exit 0
