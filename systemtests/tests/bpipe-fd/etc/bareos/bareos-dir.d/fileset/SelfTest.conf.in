FileSet {
  Name = "SelfTest"
  Enable VSS = No

  Include {
    Options {
      Signature = XXH128
    }
    Plugin = "bpipe"
             ":file=/bpipe"
             ":reader=bash ./readprogram"
             ":writer=bash ./writeprogram"
  }
}

FileSet {
  Name = bpipe-unique
  Enable VSS = No

  Include {
    Options {
       Signature = XXH128
    }

    Plugin = "bpipe"
             ":file=/bpipe"
             ":reader=bash ./readprogram"
             ":writer=bash ./writeprogram"
             ":usesuffix=true"
  }
}
