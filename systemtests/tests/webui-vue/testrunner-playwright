#!/usr/bin/env bash
#
# webui-vue system test – Playwright E2E browser tests
#
set -e
set -o pipefail
set -u

TestName="$(basename "$(pwd)")"
export TestName

#shellcheck source=../../environment.in
. ./environment

#shellcheck source=../../scripts/functions
. "${BAREOS_SCRIPTS_DIR}"/functions

start_test

PROXY_PORT="${WEBSOCKET_PROXY_PORT}"  # from CMake-allocated environment
VITE_PORT="${BAREOS_WEBUI_PORT}"      # reuse the webui port slot for Vite preview
PROXY_PID=""
VITE_PID=""

cleanup() {
  [ -n "${VITE_PID}"  ] && { kill "${VITE_PID}"  2>/dev/null || true; wait "${VITE_PID}"  2>/dev/null || true; }
  [ -n "${PROXY_PID}" ] && { kill "${PROXY_PID}" 2>/dev/null || true; wait "${PROXY_PID}" 2>/dev/null || true; }
}
trap cleanup EXIT

# Kill any leftover processes from prior runs occupying our ports.
for _port in "${VITE_PORT}" "${PROXY_PORT}"; do
  _pids=$(ss -Htlnp "sport = ${_port}" 2>/dev/null | grep -oP 'pid=\K[0-9]+' || true)
  for _pid in ${_pids}; do
    kill "${_pid}" 2>/dev/null || true
  done
done
unset _port _pids _pid

# ── 1. Build the Vue app with the test proxy WS URL baked in ─────────────────
# Only rebuild if dist/ is missing, env vars changed, or source is newer than dist.
cd "${CMAKE_SOURCE_DIR}/webui-vue"
EXPECTED_URL="ws://localhost:${PROXY_PORT}"
BUILD_ENV="VITE_DIRECTOR_WS_URL=${EXPECTED_URL}
VITE_DIRECTOR_HOST=localhost
VITE_DIRECTOR_PORT=${BAREOS_DIRECTOR_PORT}"

_needs_build=false
if [ ! -d dist ] || [ "$(cat dist/.build-env 2>/dev/null)" != "${BUILD_ENV}" ]; then
  _needs_build=true
elif find src proxy index.html -newer dist/.build-env 2>/dev/null | grep -q .; then
  _needs_build=true
fi

if [ "${_needs_build}" = true ]; then
  print_debug "Building Vue WebUI ..."
  VITE_DIRECTOR_WS_URL="${EXPECTED_URL}" \
  VITE_DIRECTOR_HOST="localhost" \
  VITE_DIRECTOR_PORT="${BAREOS_DIRECTOR_PORT}" \
    npm run build >"${tmp}/vite-build.log" 2>&1
  printf '%s' "${BUILD_ENV}" > dist/.build-env
else
  print_debug "Reusing existing Vue WebUI build."
fi
unset _needs_build

print_debug "Starting vite preview on port ${VITE_PORT} ..."
npx vite preview --port "${VITE_PORT}" --strictPort --host 127.0.0.1 >"${tmp}/vite-preview.log" 2>&1 &
VITE_PID=$!
cd -

# ── 2. Start the WS proxy against the live director ─────────────────────────
print_debug "Starting WS proxy on port ${PROXY_PORT} ..."
WS_PORT="${PROXY_PORT}" \
  "${BAREOS_WEBUI_PROXY_BINARY}" \
  >"${tmp}/ws-proxy-playwright.log" 2>&1 &
PROXY_PID=$!

# Wait for both services to be ready (poll instead of fixed sleep).
for _check_port in "${VITE_PORT}" "${PROXY_PORT}"; do
  _deadline=$(( $(date +%s) + 15 ))
  until ss -Htlnp "sport = ${_check_port}" 2>/dev/null | grep -q "${_check_port}"; do
    [ "$(date +%s)" -ge "${_deadline}" ] && { set_error "Service on port ${_check_port} did not start in time"; end_test; exit 1; }
    sleep 0.2
  done
done
unset _check_port _deadline

for pid in "${VITE_PID}" "${PROXY_PID}"; do
  if ! kill -0 "${pid}" 2>/dev/null; then
    set_error "A required service (PID ${pid}) failed to start"
    cat "${tmp}/vite-build.log" "${tmp}/vite-preview.log" "${tmp}/ws-proxy-playwright.log" 2>/dev/null || true
    end_test
    exit 1
  fi
done

# ── 3. Run Playwright tests ──────────────────────────────────────────────────
print_debug "Running Playwright E2E tests ..."
"${PYTHON_EXECUTABLE}" - <<PYEOF
import asyncio, sys, traceback
from playwright.async_api import async_playwright, expect

WEBUI_URL  = "http://localhost:${VITE_PORT}"
DIR_HOST   = "localhost"
DIR_PORT   = "${BAREOS_DIRECTOR_PORT}"
USERNAME   = "admin"
PASSWORD   = "admin"
# Director name as configured in the test's bareos-dir.d/director/*.conf
DIR_NAME   = "bareos-dir"

errors = []

def fail(msg):
    errors.append(msg)
    print(f"FAIL: {msg}", file=sys.stderr)

def ok(msg):
    print(f"OK:   {msg}")

async def login(page):
    """Fill the login form and wait for redirect to dashboard.

    Form defaults: host=localhost, port=9101, director=bareos-dir, username=admin.
    We only need to change the port (test director uses BAREOS_DIRECTOR_PORT)
    and fill the password.
    """
    await page.goto(WEBUI_URL + "/login")
    await page.wait_for_load_state("networkidle")

    # Clear and fill the embedded port number input (no accessible label of its own).
    port_input = page.locator("input[type='number']")
    await port_input.fill(DIR_PORT)

    await page.get_by_label("Password").fill(PASSWORD)
    await page.get_by_role("button", name="Login").click()

    # Wait up to 12 s for director auth round-trip and router redirect.
    await page.wait_for_url("**/dashboard", timeout=12_000)

# ── Test 1: login redirects to dashboard ─────────────────────────────────────
async def test_login(page):
    await login(page)
    if "/dashboard" in page.url:
        ok("login → redirected to /dashboard")
    else:
        fail(f"test_login: expected /dashboard, got {page.url}")

# ── Test 2: dashboard shows stat cards ───────────────────────────────────────
async def test_dashboard_stats(page):
    await login(page)
    # StatNumber components render a div with class "stat-number"
    stat = page.locator(".stat-number").first
    await expect(stat).to_be_visible(timeout=8_000)
    ok("dashboard stat card is visible")

# ── Test 3: jobs page shows real job data ────────────────────────────────────
async def test_jobs_page(page):
    await login(page)
    # Navigate within the SPA (no full reload) so the WS connection is kept.
    await page.evaluate("window.location.hash = '/jobs'")
    await page.wait_for_url("**#/jobs", timeout=5_000)
    # Wait for jobs table to populate (real data from director catalog).
    row = page.locator("td").filter(has_text="backup-bareos-fd").first
    await expect(row).to_be_visible(timeout=15_000)
    ok("jobs page shows backup-bareos-fd job")

# ── Test 4: console page accepts a command ───────────────────────────────────
async def test_console(page):
    await login(page)
    # Navigate within the SPA using hash change (no full reload).
    await page.evaluate("window.location.hash = '/console'")
    await page.wait_for_url("**#/console", timeout=5_000)
    # Wait for raw console WS to authenticate — status chip turns 'connected'.
    console_el = page.locator(".console-output")
    await expect(console_el).to_contain_text("Connected to", timeout=12_000)
    # Click to focus the terminal, then type a command.
    await console_el.click()
    await page.keyboard.type("list clients")
    await page.keyboard.press("Enter")
    # The response area renders "bareos-fd" from the live director.
    await expect(console_el).to_contain_text("bareos-fd", timeout=12_000)
    ok("console page returns output for 'list clients'")

# ── Test 5: page reload reconnects automatically ──────────────────────────────
async def test_reload_reconnects(page):
    await login(page)
    # Full page reload — WS is lost, credentials stay in sessionStorage.
    await page.reload()
    await page.wait_for_load_state("networkidle")
    # Should still be on dashboard (not redirected to login).
    await page.wait_for_url("**#/dashboard", timeout=8_000)
    # Navigate to jobs page and wait for real job data — proves WS reconnected
    # and data was actually fetched (not just the card skeleton).
    await page.evaluate("window.location.hash = '/jobs'")
    await page.wait_for_url("**#/jobs", timeout=5_000)
    row = page.locator("td").filter(has_text="backup-bareos-fd").first
    await expect(row).to_be_visible(timeout=15_000)
    ok("page reload reconnects and fetches real data")

# ── Test 6: logout returns to login page ─────────────────────────────────────
async def test_logout(page):
    await login(page)
    # User button label is the username ("admin") — click to open dropdown.
    await page.get_by_role("button", name="admin").click()
    # Quasar teleports the dropdown into a portal div (#q-portal--menu--N).
    # Restrict to .q-menu to avoid hitting the original placeholder in #app.
    await page.locator(".q-menu").get_by_text("Logout", exact=True).click()
    await page.wait_for_url("**/login", timeout=5_000)
    ok("logout → redirected to /login")

async def main():
    tests = [
        test_login,
        test_dashboard_stats,
        test_jobs_page,
        test_console,
        test_reload_reconnects,
        test_logout,
    ]

    async with async_playwright() as pw:
        browser = await pw.chromium.launch(headless=True)
        for t in tests:
            page = await browser.new_page()
            try:
                await t(page)
            except Exception:
                fail(f"{t.__name__}: {traceback.format_exc()}")
            finally:
                await page.close()
        await browser.close()

    if errors:
        print(f"\n{len(errors)} test(s) FAILED:", file=sys.stderr)
        for e in errors:
            print(f"  - {e}", file=sys.stderr)
        sys.exit(1)
    else:
        print(f"\nAll {len(tests)} E2E tests passed.")

asyncio.run(main())
PYEOF

end_test

