#!/bin/bash
#
# webui-vue system test – run real backup jobs
#
# Runs Full + Incremental backup job pairs for two clients (bareos-fd and
# bareos-fd2) and two filesets each, so the catalog contains genuine data
# for multiple clients:
#   Job backup-bareos-fd   – bareos-fd  client, SelfTest fileset
#   Job backup-bareos-fd-2 – bareos-fd  client, TestData2 fileset
#   Job backup-bareos-fd2  – bareos-fd2 client, SelfTest fileset
#   Job backup-bareos-fd2-2– bareos-fd2 client, TestData2 fileset
#
set -e
set -o pipefail
set -u

TestName="$(basename "$(pwd)")"
export TestName

#shellcheck source=../../environment.in
. ./environment

#shellcheck source=../../scripts/functions
. "${BAREOS_SCRIPTS_DIR}"/functions

start_test

# ── Populate the second backup directory with many small files ─────────────
# The first directory (${BackupDirectory}) was already populated by setup_data
# in test-setup.  We create a separate tree for job 2.
BACKUP_DIR2="${BackupDirectory}2"
mkdir -p "${BACKUP_DIR2}/docs" \
         "${BACKUP_DIR2}/src/lib" \
         "${BACKUP_DIR2}/src/tests" \
         "${BACKUP_DIR2}/config" \
         "${BACKUP_DIR2}/logs"

# Generate lots of small files quickly
for i in $(seq 1 50); do
  printf 'content of doc %d\n' "$i" > "${BACKUP_DIR2}/docs/doc${i}.txt"
done
for i in $(seq 1 40); do
  printf '// source file %d\n' "$i" > "${BACKUP_DIR2}/src/lib/lib${i}.c"
done
for i in $(seq 1 20); do
  printf '// test %d\n' "$i" > "${BACKUP_DIR2}/src/tests/test${i}.c"
done
for i in $(seq 1 10); do
  printf 'key%d=value\n' "$i" > "${BACKUP_DIR2}/config/app${i}.conf"
done
for i in $(seq 1 30); do
  printf '2026-03-30 log line %d\n' "$i" > "${BACKUP_DIR2}/logs/run${i}.log"
done

# Write file-list for the TestData2 fileset
echo "${BACKUP_DIR2}" > "${tmp}/file-list2"

# Create updated.conf in the primary backup dir so it is captured in Full
printf 'version=1.0\n' > "${BackupDirectory}/updated.conf"

# ── Run Full backups for all four jobs (both clients) ─────────────────────
cat <<END_OF_DATA >"${tmp}/bconcmds"
@$out ${NULL_DEV}
messages
@$out ${tmp}/log-full.out
label volume=TestVolume001 storage=File pool=Full
label volume=TestVolume002 storage=File pool=Incremental
run job=backup-bareos-fd level=Full yes
run job=backup-bareos-fd-2 level=Full yes
run job=backup-bareos-fd2 level=Full yes
run job=backup-bareos-fd2-2 level=Full yes
wait
messages
quit
END_OF_DATA

run_bconsole

# ── Add a few new files then run Incremental backups ──────────────────────
for i in $(seq 51 60); do
  printf 'new doc %d\n' "$i" > "${BACKUP_DIR2}/docs/doc${i}.txt"
done
# Modify updated.conf so it is captured again in the Incremental backup,
# giving us two distinct versions to test the version restore feature.
printf 'version=2.0\nupdated=yes\n' > "${BackupDirectory}/updated.conf"

cat <<END_OF_DATA >"${tmp}/bconcmds"
@$out ${NULL_DEV}
messages
@$out ${tmp}/log-incr.out
run job=backup-bareos-fd level=Incremental yes
run job=backup-bareos-fd-2 level=Incremental yes
run job=backup-bareos-fd2 level=Incremental yes
run job=backup-bareos-fd2-2 level=Incremental yes
wait
messages
quit
END_OF_DATA

run_bconsole

# ── Verify all jobs completed without errors ──────────────────────────────
check_log "${tmp}/log-full.out"
check_log "${tmp}/log-incr.out"

end_test
