#!/bin/bash
#
# webui-vue system test – setup fixture
#
# Cleans any previous run, starts Director/SD/FD, and verifies that all
# daemons are ready before the individual testrunner-* scripts execute.
#
set -e
set -o pipefail
set -u

#shellcheck source=../../environment.in
. ./environment

#shellcheck source=../../scripts/functions
. "${BAREOS_SCRIPTS_DIR}"/functions

"${BAREOS_SCRIPTS_DIR}"/cleanup
"${BAREOS_SCRIPTS_DIR}"/setup

# Populate the backup source directory with small test files.
setup_data

bin/bareos start
bin/bareos status

# Confirm the director is responsive before handing off to testrunner-*.
print_debug "$(bin/bconsole <<<"status dir")"

# ── Ensure the production dist/ is up to date ────────────────────────────────
# dist/ contains the committed production build (no VITE_* env vars).
# Rebuild it here if any source file is newer so the committed artifact stays
# current.  Tests never use dist/ directly; they build and serve test-dist/.
_vue_src="${CMAKE_SOURCE_DIR}/webui-vue"
_needs_prod_build=false
if [ ! -d "${_vue_src}/dist" ]; then
  _needs_prod_build=true
elif (cd "${_vue_src}" \
  && find src index.html vite.config.js -newer dist/index.html 2>/dev/null \
  | grep -q .); then
  _needs_prod_build=true
fi

if [ "${_needs_prod_build}" = true ]; then
  print_debug "Rebuilding production dist/ ..."
  (
    cd "${_vue_src}"
    npm run build >"${tmp}/vite-build-prod.log" 2>&1
  )
  print_debug "Production dist/ rebuild complete."
fi
unset _vue_src _needs_prod_build
