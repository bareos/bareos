#!/bin/bash
#
# Start or stop the Bareos WebSocket proxy (bareos-webui-proxy).
#
# The proxy bridges browser WebSocket connections to the Bareos director
# using the CRAM-MD5 mutual-authentication protocol.
#
# Usage (run from the webui-vue systemtest directory):
#   bin/webui-proxy start   – start the proxy
#   bin/webui-proxy stop    – stop the proxy
#   bin/webui-proxy status  – show whether the proxy is running
#

set -e
set -o pipefail
set -u

#shellcheck source=../../environment.in
. ./environment

TESTDIR="$(pwd)"
PROXY_PIDFILE="${TESTDIR}/tmp/ws-proxy.pid"
PROXY_LOG="${TESTDIR}/tmp/ws-proxy-manual.log"

proxy_ws_url="ws://127.0.0.1:${WEBSOCKET_PROXY_PORT}"

# ── helpers ──────────────────────────────────────────────────────────────────

is_running()
{
  local pidfile="$1"
  [ -f "${pidfile}" ] && kill -0 "$(cat "${pidfile}")" 2>/dev/null
}

wait_for_port()
{
  local port="$1" deadline
  deadline=$(($(date +%s) + 15))
  until ss -Htlnp "sport = ${port}" 2>/dev/null | grep -q "${port}"; do
    if [ "$(date +%s)" -ge "${deadline}" ]; then
      echo "ERROR: proxy did not bind port ${port} within 15 s" >&2
      return 1
    fi
    sleep 0.2
  done
}

# ── start ─────────────────────────────────────────────────────────────────────

do_start()
{
  if is_running "${PROXY_PIDFILE}"; then
    echo "webui-proxy is already running (PID $(cat "${PROXY_PIDFILE}"))."
    exit 1
  fi

  mkdir -p tmp

  echo "Starting WS proxy on port ${WEBSOCKET_PROXY_PORT} ..."
  WS_PORT="${WEBSOCKET_PROXY_PORT}" \
    BAREOS_DIRECTOR_HOST="${BAREOS_DIRECTOR_ADDRESS:-localhost}" \
    BAREOS_DIRECTOR_PORT="${BAREOS_DIRECTOR_PORT}" \
    "${BAREOS_WEBUI_PROXY_BINARY}"
  #    >"${PROXY_LOG}" 2>&1 &
  echo $! >"${PROXY_PIDFILE}"
  wait_for_port "${WEBSOCKET_PROXY_PORT}"
  echo "WS proxy running (PID $(cat "${PROXY_PIDFILE}"))."
  echo ""
  echo "WebSocket endpoint: ${proxy_ws_url}"
  echo "Log:                ${PROXY_LOG}"
}

# ── stop ──────────────────────────────────────────────────────────────────────

do_stop()
{
  if [ -f "${PROXY_PIDFILE}" ]; then
    pid=$(cat "${PROXY_PIDFILE}")
    if kill -0 "${pid}" 2>/dev/null; then
      kill "${pid}" && echo "Stopped PID ${pid}."
    else
      echo "PID ${pid} is not running."
    fi
    rm -f "${PROXY_PIDFILE}"
  else
    echo "Nothing was running (no pidfile found)."
  fi
}

# ── status ────────────────────────────────────────────────────────────────────

do_status()
{
  if is_running "${PROXY_PIDFILE}"; then
    echo "WS proxy: running (PID $(cat "${PROXY_PIDFILE}"))"
    echo "Endpoint: ${proxy_ws_url}"
  else
    echo "WS proxy: stopped"
  fi
}

# ── dispatch ──────────────────────────────────────────────────────────────────

case "${1-}" in
  start) do_start ;;
  stop) do_stop ;;
  status) do_status ;;
  *)
    echo "Usage: $0 {start|stop|status}"
    exit 1
    ;;
esac
