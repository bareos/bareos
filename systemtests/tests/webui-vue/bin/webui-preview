# webui-preview – interactive manual-testing helper for webui-vue
#
# Sets up the full test environment (Bareos daemons + catalog + backup jobs
# + WS proxy + Vite preview), opens a browser, then waits for the user to
# press Enter before tearing everything down cleanly.
#
# Run from the cmake-build webui-vue test directory:
#   cd cmake-build/systemtests/tests/webui-vue
#   bin/webui-preview
#

set -e
set -o pipefail
set -u

# ── environment ───────────────────────────────────────────────────────────────

# shellcheck source=../../environment.in
. ./environment

# shellcheck source=../../scripts/functions
. "${BAREOS_SCRIPTS_DIR}/functions"

TESTDIR="$(pwd)"
PROXY_LOG="${TESTDIR}/tmp/ws-proxy-preview.log"
VITE_LOG="${TESTDIR}/tmp/vite-preview-preview.log"
VITE_BUILD_LOG="${TESTDIR}/tmp/vite-build-preview.log"
PROXY_PID=""
VITE_PID=""

# ── cleanup trap ──────────────────────────────────────────────────────────────

cleanup()
{
  echo ""
  echo "==> Stopping Vite preview and WS proxy ..."
  [ -n "${VITE_PID}" ] && {
    kill "${VITE_PID}" 2>/dev/null || true
    wait "${VITE_PID}" 2>/dev/null || true
  }
  [ -n "${PROXY_PID}" ] && {
    kill "${PROXY_PID}" 2>/dev/null || true
    wait "${PROXY_PID}" 2>/dev/null || true
  }

  echo "==> Stopping Bareos daemons ..."
  stop_bareos 2>/dev/null || true
}
trap cleanup EXIT

# Kill any processes from prior interrupted runs that are still holding ports.
for _port in "${BAREOS_WEBUI_PORT}" "${WEBSOCKET_PROXY_PORT}"; do
  _pids=$(ss -Htlnp "sport = ${_port}" 2>/dev/null \
    | grep -oP 'pid=\K[0-9]+' || true)
  for _pid in ${_pids}; do
    kill "${_pid}" 2>/dev/null || true
  done
done
unset _port _pids _pid

# ── 1. Set up a clean Bareos environment ─────────────────────────────────────

echo "==> Cleaning up previous test state ..."
"${BAREOS_SCRIPTS_DIR}/cleanup"

echo "==> Setting up catalog and config ..."
"${BAREOS_SCRIPTS_DIR}/setup"

echo "==> Populating backup source directory ..."
setup_data
mkdir -p "${tmp}"

echo "==> Starting Bareos daemons ..."
start_bareos

# ── 2. Run backup jobs to fill the catalog ───────────────────────────────────

echo "==> Running backup jobs ..."

BACKUP_DIR2="${BackupDirectory}2"
mkdir -p "${BACKUP_DIR2}/docs" \
         "${BACKUP_DIR2}/src/lib" \
         "${BACKUP_DIR2}/src/tests" \
         "${BACKUP_DIR2}/config" \
         "${BACKUP_DIR2}/logs"

for i in $(seq 1 50); do
  printf 'content of doc %d\n' "$i" > "${BACKUP_DIR2}/docs/doc${i}.txt"
done
for i in $(seq 1 40); do
  printf '// source file %d\n' "$i" > "${BACKUP_DIR2}/src/lib/lib${i}.c"
done
for i in $(seq 1 20); do
  printf '// test %d\n' "$i" > "${BACKUP_DIR2}/src/tests/test${i}.c"
done
for i in $(seq 1 10); do
  printf 'key%d=value\n' "$i" > "${BACKUP_DIR2}/config/app${i}.conf"
done
for i in $(seq 1 30); do
  printf '2026-03-30 log line %d\n' "$i" > "${BACKUP_DIR2}/logs/run${i}.log"
done
printf 'version=1.0\n' > "${BackupDirectory}/updated.conf"
echo "${BACKUP_DIR2}" > "${tmp}/file-list2"

cat <<END_OF_DATA >"${tmp}/bconcmds"
@\$out ${NULL_DEV}
messages
@\$out ${tmp}/log-preview-full.out
label volume=TestVolume001 storage=File pool=Full
label volume=TestVolume002 storage=File pool=Incremental
run job=backup-bareos-fd level=Full yes
run job=backup-bareos-fd-2 level=Full yes
wait
messages
quit
END_OF_DATA
run_bconsole

for i in $(seq 51 60); do
  printf 'new doc %d\n' "$i" > "${BACKUP_DIR2}/docs/doc${i}.txt"
done
printf 'version=2.0\nupdated=yes\n' > "${BackupDirectory}/updated.conf"

cat <<END_OF_DATA >"${tmp}/bconcmds"
@\$out ${NULL_DEV}
messages
@\$out ${tmp}/log-preview-incr.out
run job=backup-bareos-fd level=Incremental yes
run job=backup-bareos-fd-2 level=Incremental yes
wait
messages
quit
END_OF_DATA
run_bconsole

echo "==> Backup jobs complete."

# ── 3. Build Vue test app ─────────────────────────────────────────────────────

cd "${CMAKE_SOURCE_DIR}/webui-vue"
TEST_DIST="test-dist"
EXPECTED_URL="ws://localhost:${WEBSOCKET_PROXY_PORT}"
BUILD_ENV="VITE_DIRECTOR_WS_URL=${EXPECTED_URL}
VITE_DIRECTOR_HOST=localhost
VITE_DIRECTOR_PORT=${BAREOS_DIRECTOR_PORT}"

_needs_build=false
if [ ! -d "${TEST_DIST}" ] \
  || [ "$(cat "${TEST_DIST}/.build-env" 2>/dev/null)" != "${BUILD_ENV}" ]; then
  _needs_build=true
elif find src index.html -newer "${TEST_DIST}/.build-env" 2>/dev/null \
  | grep -q .; then
  _needs_build=true
fi

if [ "${_needs_build}" = true ]; then
  echo "==> Building Vue WebUI ..."
  VITE_DIRECTOR_WS_URL="${EXPECTED_URL}" \
    VITE_DIRECTOR_HOST="localhost" \
    VITE_DIRECTOR_PORT="${BAREOS_DIRECTOR_PORT}" \
    npx vite build --outDir "${TEST_DIST}" >"${VITE_BUILD_LOG}" 2>&1
  printf '%s' "${BUILD_ENV}" >"${TEST_DIST}/.build-env"
  echo "==> Build complete."
else
  echo "==> Reusing existing Vue WebUI test build."
fi
unset _needs_build
cd "${TESTDIR}"

# ── 4. Start WS proxy ─────────────────────────────────────────────────────────

echo "==> Starting WS proxy on port ${WEBSOCKET_PROXY_PORT} ..."
WS_PORT="${WEBSOCKET_PROXY_PORT}" \
  "${BAREOS_WEBUI_PROXY_BINARY}" \
  >"${PROXY_LOG}" 2>&1 &
PROXY_PID=$!

_deadline=$(($(date +%s) + 15))
until ss -Htlnp "sport = ${WEBSOCKET_PROXY_PORT}" 2>/dev/null \
  | grep -q "${WEBSOCKET_PROXY_PORT}"; do
  [ "$(date +%s)" -ge "${_deadline}" ] && {
    echo "ERROR: WS proxy did not start in time." >&2
    exit 1
  }
  sleep 0.2
done
unset _deadline

# ── 5. Start Vite preview ─────────────────────────────────────────────────────

echo "==> Starting Vite preview on port ${BAREOS_WEBUI_PORT} ..."
(
  cd "${CMAKE_SOURCE_DIR}/webui-vue"
  npx vite preview \
    --outDir test-dist \
    --port "${BAREOS_WEBUI_PORT}" \
    --strictPort --host 127.0.0.1 \
    >"${VITE_LOG}" 2>&1
) &
VITE_PID=$!

_deadline=$(($(date +%s) + 15))
until ss -Htlnp "sport = ${BAREOS_WEBUI_PORT}" 2>/dev/null \
  | grep -q "${BAREOS_WEBUI_PORT}"; do
  [ "$(date +%s)" -ge "${_deadline}" ] && {
    echo "ERROR: Vite preview did not start in time." >&2
    exit 1
  }
  sleep 0.2
done
unset _deadline

# ── 6. Open browser and wait ──────────────────────────────────────────────────

WEBUI_URL="http://127.0.0.1:${BAREOS_WEBUI_PORT}"

echo ""
echo "======================================================"
echo " Vue WebUI ready for manual testing"
echo "======================================================"
echo " URL:          ${WEBUI_URL}"
echo " Login port:   ${BAREOS_DIRECTOR_PORT}  (pre-filled)"
echo " Username:     admin"
echo " Password:     admin"
echo " WS proxy log: ${PROXY_LOG}"
echo " Vite log:     ${VITE_LOG}"
echo "======================================================"
echo ""

xdg-open "${WEBUI_URL}" >/dev/null 2>&1 || true

read -r -p "Press Enter to stop everything and clean up ... "
