set -e
set -o pipefail
set -u

TestName="$(basename "$(pwd)")"
export TestName

#shellcheck source=../../environment.in
. ./environment

#shellcheck source=../../scripts/functions
. "${BAREOS_SCRIPTS_DIR}/functions"

# Fill ${BackupDirectory} with data.
setup_data

start_test

check_php_is_running

# run tests

if ! ${PYTHON_EXECUTABLE} ${CMAKE_SOURCE_DIR}/webui/tests/selenium/webui-php-selenium-test.py -v "SeleniumTest.test_@BAREOS_WEBUI_TESTNAME@" >>"${runner_tmp}/selenium.out" 2>&1; then
  set_error "$(cat "${runner_tmp}/selenium.out")"
fi

end_test
