set -e
set -o pipefail
set -u

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
REPO_ROOT=$(cd -- "${SCRIPT_DIR}/../../.." && pwd)
BUILD_TEST_DIR="${REPO_ROOT}/cmake-build/systemtests/tests/setup-wizard"
ENVIRONMENT_FILE="${BUILD_TEST_DIR}/environment"

#shellcheck source=../../environment.in
. "${ENVIRONMENT_FILE}"

IMAGE_NAME=localhost/bareos-setup-wizard:alma10
CONTAINER_NAME=bareos-setup-wizard-alma10
STATE_ROOT="${current_test_directory}/podman-state"
BCONFIG_PORT=$((BASEPORT + 8))
SETUP_REPOSITORY_PATH=/var/lib/bconfig/deployments/prod
SETUP_RUNTIME_ROOT=/var/lib/bareos
SETUP_DIRECTOR_PORT=9101
SETUP_CLIENT_PORT=9102
SETUP_STORAGE_PORT=9103
SOURCE_SETUP_DIR="${CMAKE_SOURCE_DIR}/systemtests/tests/setup-wizard"
PLAYWRIGHT_ARTIFACTS_DIR="${current_test_directory}/playwright-artifacts"
SETUP_CONSOLE_PASSWORD="wizard-secret"

ensure_state_dirs()
{
  mkdir -p \
    "${STATE_ROOT}/etc/bareos" \
    "${STATE_ROOT}/var/lib/bconfig" \
    "${STATE_ROOT}/var/lib/bareos" \
    "${STATE_ROOT}/var/lib/pgsql" \
    "${STATE_ROOT}/var/log/bareos" \
    "${STATE_ROOT}/var/log/postgresql" \
    "${STATE_ROOT}/var/log/setup-wizard"
}

remove_state_root()
{
  podman unshare rm -rf "${STATE_ROOT}"
}

build_image()
{
  podman build \
    --tag "${IMAGE_NAME}" \
    --file "${SOURCE_SETUP_DIR}/Containerfile.almalinux10" \
    "${SOURCE_SETUP_DIR}"
}

start_container()
{
  remove_state_root
  ensure_state_dirs

  podman run -d \
    --name "${CONTAINER_NAME}" \
    --replace \
    --hostname bareos-setup-wizard-alma10 \
    --privileged \
    --systemd=always \
    --tmpfs /run \
    --tmpfs /run/lock \
    -p "127.0.0.1:${BAREOS_WEBUI_PORT}:${BAREOS_WEBUI_PORT}" \
    -v "${CMAKE_SOURCE_DIR}:${CMAKE_SOURCE_DIR}:ro,Z" \
    -v "${CMAKE_BINARY_DIR}:${CMAKE_BINARY_DIR}:ro,Z" \
    -v /lib64/libfmt.so.11.2.0:/lib64/libfmt.so.11:ro \
    -v /lib64/libxxhash.so.0.8.3:/lib64/libxxhash.so.0:ro \
    -v /sys/fs/cgroup:/sys/fs/cgroup:rw \
    -v "${STATE_ROOT}/etc/bareos:/etc/bareos:Z" \
    -v "${STATE_ROOT}/var/lib/bconfig:/var/lib/bconfig:Z" \
    -v "${STATE_ROOT}/var/lib/bareos:/var/lib/bareos:Z" \
    -v "${STATE_ROOT}/var/lib/pgsql:/var/lib/pgsql:Z" \
    -v "${STATE_ROOT}/var/log/bareos:/var/log/bareos:Z" \
    -v "${STATE_ROOT}/var/log/postgresql:/var/log/postgresql:Z" \
    -v "${STATE_ROOT}/var/log/setup-wizard:/var/log/setup-wizard:Z" \
    -e BAREOS_SOURCE_DIR="${CMAKE_SOURCE_DIR}" \
    -e BAREOS_BUILD_DIR="${CMAKE_BINARY_DIR}" \
    -e BAREOS_BCONFIG_PORT="${BCONFIG_PORT}" \
    -e BAREOS_WEBUI_PORT="${BAREOS_WEBUI_PORT}" \
    -e BAREOS_WEBUI_PROXY_PORT="${BAREOS_WEBUI_PROXY_PORT}" \
    -e BAREOS_SETUP_REPOSITORY_PATH="${SETUP_REPOSITORY_PATH}" \
    -e BAREOS_SETUP_RUNTIME_ROOT="${SETUP_RUNTIME_ROOT}" \
    -e BAREOS_SETUP_DIRECTOR_PORT="${SETUP_DIRECTOR_PORT}" \
    -e BAREOS_SETUP_CLIENT_PORT="${SETUP_CLIENT_PORT}" \
    -e BAREOS_SETUP_STORAGE_PORT="${SETUP_STORAGE_PORT}" \
    "${IMAGE_NAME}" \
    /sbin/init

  for _ in $(seq 1 90); do
    if podman exec "${CONTAINER_NAME}" systemctl list-units >/dev/null 2>&1; then
      break
    fi
    sleep 1
  done

  podman exec \
    --env BAREOS_SOURCE_DIR="${CMAKE_SOURCE_DIR}" \
    --env BAREOS_BUILD_DIR="${CMAKE_BINARY_DIR}" \
    --env BAREOS_BCONFIG_PORT="${BCONFIG_PORT}" \
    --env BAREOS_WEBUI_PORT="${BAREOS_WEBUI_PORT}" \
    --env BAREOS_WEBUI_PROXY_PORT="${BAREOS_WEBUI_PROXY_PORT}" \
    --env BAREOS_SETUP_REPOSITORY_PATH="${SETUP_REPOSITORY_PATH}" \
    --env BAREOS_SETUP_RUNTIME_ROOT="${SETUP_RUNTIME_ROOT}" \
    --env BAREOS_SETUP_DIRECTOR_PORT="${SETUP_DIRECTOR_PORT}" \
    --env BAREOS_SETUP_CLIENT_PORT="${SETUP_CLIENT_PORT}" \
    --env BAREOS_SETUP_STORAGE_PORT="${SETUP_STORAGE_PORT}" \
    "${CONTAINER_NAME}" \
    /bin/bash "${CMAKE_SOURCE_DIR}/systemtests/tests/setup-wizard/podman-entrypoint.sh"
}

wait_ready()
{
  for _ in $(seq 1 90); do
    if curl --silent --fail "http://127.0.0.1:${BAREOS_WEBUI_PORT}/" >/dev/null; then
      return 0
    fi
    sleep 1
  done
  return 1
}

run_e2e()
{
  mkdir -p "${PLAYWRIGHT_ARTIFACTS_DIR}"

  cd "${CMAKE_SOURCE_DIR}/webui-vue"
  PLAYWRIGHT_BASE_URL="http://127.0.0.1:${BAREOS_WEBUI_PORT}/" \
    PLAYWRIGHT_ARTIFACTS_DIR="${PLAYWRIGHT_ARTIFACTS_DIR}" \
    GOOGLE_CHROME_EXECUTABLE="${GOOGLE_CHROME_EXECUTABLE:-}" \
    BAREOS_SETUP_REPOSITORY_PATH="${SETUP_REPOSITORY_PATH}" \
    BAREOS_SETUP_RUNTIME_ROOT="${SETUP_RUNTIME_ROOT}" \
    BAREOS_SETUP_DIRECTOR_PORT="${SETUP_DIRECTOR_PORT}" \
    BAREOS_SETUP_CLIENT_PORT="${SETUP_CLIENT_PORT}" \
    BAREOS_SETUP_STORAGE_PORT="${SETUP_STORAGE_PORT}" \
    BAREOS_SETUP_CONSOLE_PASSWORD="${SETUP_CONSOLE_PASSWORD}" \
    "${NPM_EXECUTABLE}" run test:e2e -- tests/e2e/setup-wizard.spec.js

  podman exec "${CONTAINER_NAME}" sh -lc '
    test -f /etc/bareos/bareos-dir.d/director/bareos-dir.conf &&
    test -f /etc/bareos/bareos-sd.d/storage/bareos-sd.conf &&
    test -f /etc/bareos/bareos-fd.d/client/bareos-fd.conf &&
    test -f /etc/bareos/bconsole.conf &&
    systemctl is-active bareos-dir.service bareos-sd.service bareos-fd.service
  '
}

case "${1-}" in
  build)
    build_image
    ;;
  start)
    if ! podman image exists "${IMAGE_NAME}"; then
      build_image
    fi
    start_container
    wait_ready
    cat <<EOF
Podman setup-wizard stack is running.
Frontend URL: http://127.0.0.1:${BAREOS_WEBUI_PORT}/#/setup
Suggested repository path: ${SETUP_REPOSITORY_PATH}
Suggested runtime root: ${SETUP_RUNTIME_ROOT}
Suggested daemon ports: ${SETUP_DIRECTOR_PORT}/${SETUP_CLIENT_PORT}/${SETUP_STORAGE_PORT}
Host state root: ${STATE_ROOT}
EOF
    ;;
  stop)
    podman rm -f "${CONTAINER_NAME}" >/dev/null 2>&1 || true
    ;;
  status)
    podman ps --filter "name=${CONTAINER_NAME}" --format '{{.Names}} {{.Status}}'
    curl --silent --fail "http://127.0.0.1:${BAREOS_WEBUI_PORT}/" >/dev/null
    podman exec "${CONTAINER_NAME}" curl --silent --fail \
      "http://127.0.0.1:${BCONFIG_PORT}/api/bconfig/v1/deployments"
    ;;
  logs)
    podman exec "${CONTAINER_NAME}" journalctl --no-pager -u postgresql.service \
      -u bconfig-service.service -u bareos-webui-proxy.service \
      -u setup-wizard-frontend.service
    ;;
  e2e)
    if ! podman ps --filter "name=${CONTAINER_NAME}" --format '{{.Names}}' \
      | grep -qx "${CONTAINER_NAME}"; then
      if ! podman image exists "${IMAGE_NAME}"; then
        build_image
      fi
      start_container
      wait_ready
    fi
    run_e2e
    ;;
  shell)
    exec podman exec -it "${CONTAINER_NAME}" /bin/bash
    ;;
  clean)
    podman rm -f "${CONTAINER_NAME}" >/dev/null 2>&1 || true
    remove_state_root
    ;;
  *)
    echo "Usage: $0 {build|start|stop|status|logs|e2e|shell|clean}"
    exit 1
    ;;
esac
