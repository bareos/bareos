#!/bin/bash

set -e
set -o pipefail
set -u

#shellcheck source=../../environment.in
. ./environment

SETUP_DIRECTOR_PORT=$((20000 + BASEPORT))
SETUP_CLIENT_PORT=$((20001 + BASEPORT))
SETUP_STORAGE_PORT=$((20002 + BASEPORT))
SETUP_RUNTIME_ROOT="${current_test_directory}/var/lib/bareos-runtime"
SETUP_REPOSITORY_PATH="${current_test_directory}/var/lib/bconfig/deployments/prod"

case "${1-}" in
  start)
    ./test-setup
    cat <<EOF
Manual setup-wizard stack is running.
Frontend URL: http://127.0.0.1:${BAREOS_WEBUI_PORT}/
Suggested repository path: ${SETUP_REPOSITORY_PATH}
Suggested runtime root: ${SETUP_RUNTIME_ROOT}
Suggested daemon ports: ${SETUP_DIRECTOR_PORT}/${SETUP_CLIENT_PORT}/${SETUP_STORAGE_PORT}
EOF
    ;;
  stop)
    ./test-cleanup
    ;;
  status)
    curl --silent --fail "http://127.0.0.1:${BAREOS_WEBUI_PORT}/" >/dev/null
    curl --silent --fail "http://127.0.0.1:$((BASEPORT + 8))/api/bconfig/v1/deployments"
    ;;
  *)
    echo "Usage: $0 {start|stop|status}"
    exit 1
    ;;
esac
