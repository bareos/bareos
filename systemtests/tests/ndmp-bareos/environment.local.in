runner_name="$(basename "$0")"
export log_home="${tmp}/${runner_name}"
mkdir -p "${log_home}"

IP_ADDRESS_TO_ACCESS_NDMP_DATA_AGENT=@IP_ADDRESS_TO_ACCESS_NDMP_DATA_AGENT@
NDMP_TEST=@ndmp_test@
NDMP_CLIENT=@ndmp_test@
NDMP_DATA_AGENT_ADDRESS=@ndmp_data_agent_address@
NDMP_MOUNTPOINT=@ndmp_data_mountpoint@
NDMP_TEST_PATH=${NDMP_MOUNTPOINT}/home/regress/${IP_ADDRESS_TO_ACCESS_NDMP_DATA_AGENT}/${TestName}
export NDMP_HOST_ADDRESS=${NDMP_DATA_AGENT_ADDRESS}
export NDMP_TEST_PATH
