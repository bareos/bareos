set -e
set -o pipefail
set -u

TestName="$(basename "$(pwd)")"
export TestName

. ./environment
. "${BAREOS_SCRIPTS_DIR}/functions"

for pid_file in "${tmp}/webui-vue-frontend.pid" "${tmp}/webui-vue-proxy.pid"; do
  if [[ -f "${pid_file}" ]]; then
    pid="$(<"${pid_file}")"
    if [[ -n "${pid}" ]] && kill -0 "${pid}" >/dev/null 2>&1; then
      kill "${pid}" || true
      wait "${pid}" || true
    fi
    rm -f "${pid_file}"
  fi
done

stop_bareos || true
${BAREOS_SCRIPTS_DIR}/cleanup
