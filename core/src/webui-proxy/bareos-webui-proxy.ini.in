# bareos-webui-proxy configuration
#
# [listen] configures where the proxy accepts WebSocket connections.
# Each [director:<id>] section defines one Bareos Director the proxy may use.
# If exactly one director is configured, it is used automatically.
# If multiple directors are configured, the WebUI must select one by id.
[listen]
ws_host = localhost
ws_port = 8765
session_ttl = 28800

[director:bareos-dir]
host = localhost
port = 9101
director_name = bareos-dir
tls_psk_disable = false

#[auth-user:demo-admin]
#username = demo-admin
#password_hash = pbkdf2-sha256$600000$00112233445566778899aabbccddeeff$96666a043e8f5c98df6e3babfd926c3bf48788e81ed82927b71dd7ece1da7d6a
#groups = backup-admins
#roles = operator

#[auth-token:ci-bot]
#token_hash = sha256$94313d1c406f7af5469a1e7145dfce63a8d46d6e2523d39114f6bc9e864eb518
#subject = ci-bot
#groups = automation
#roles = operator

#[auth-oidc:example]
#display_name = Example Identity
#issuer = https://id.example.test
#authorization_endpoint = https://id.example.test/oauth2/authorize
#client_id = bareos-webui
#client_secret = replace-me
#redirect_uri = https://webui.example.test/api/v1/auth/oidc/example/callback
#scopes = openid, profile, email

#[identity-map:webui-admin]
#provider = local
#username = demo-admin
#director_username = webui-admin
#director_password = secret
#preferred_director = bareos-dir

#[identity-map:ci-bot]
#provider = token
#subject = ci-bot
#director_username = limited-operator
#director_password = secret
#preferred_director = bareos-dir

#[identity-map:oidc-admin]
#provider = oidc
#subject = 248289761001
#director_username = webui-admin
#director_password = secret
#preferred_director = bareos-dir

#[director:dr-site]
#host = dr.example.com
#port = 9101
#director_name = bareos-dir-dr
#tls_psk_disable = false
