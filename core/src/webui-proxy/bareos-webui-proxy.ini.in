# bareos-webui-proxy configuration
#
# [listen] configures where the proxy accepts WebSocket connections.
# Each [director:<id>] section defines one Bareos Director the proxy may use.
# If exactly one director is configured, it is used automatically.
# If multiple directors are configured, the WebUI must select one by id.
[listen]
ws_host = localhost
ws_port = 8765
session_ttl = 28800

[director:bareos-dir]
host = localhost
port = 9101
director_name = bareos-dir
tls_psk_disable = false

#[auth-user:demo-admin]
#username = demo-admin
#password_hash = pbkdf2-sha256$600000$00112233445566778899aabbccddeeff$96666a043e8f5c98df6e3babfd926c3bf48788e81ed82927b71dd7ece1da7d6a
#groups = backup-admins
#roles = operator

#[identity-map:webui-admin]
#provider = local
#username = demo-admin
#director_username = webui-admin
#director_password = secret
#preferred_director = bareos-dir

#[director:dr-site]
#host = dr.example.com
#port = 9101
#director_name = bareos-dir-dr
#tls_psk_disable = false
