# List units used aggregated per plugin.
# Parameters:
# - placeholder for WITH clause
#   inject the snippet from subscription_with_clause_0 here
%s
SELECT
  plugin,
  count,
  size_gb::NUMERIC(20,2),
  size_source
FROM (
  SELECT
    plugin,
    count,
    size_gb,
    size_source,
    1 AS order 
  FROM plugin_aggregated
  UNION
  SELECT
    'TOTAL' as plugin,
    SUM(count) as count,
    SUM(size_gb) AS size_gb,
    CASE
      WHEN COUNT(DISTINCT size_source) = 1 THEN MIN(size_source)
      ELSE 'mixed'
    END AS size_source,
    2 AS order
  FROM plugin_aggregated
) t
ORDER BY t.order, t.plugin;
