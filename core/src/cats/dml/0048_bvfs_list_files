SELECT TYPE,
       PathId,
       Name,
       JobId,
       LStat,
       FileId
FROM (
   SELECT DISTINCT ON (File.Name) 'F' AS TYPE,
                                  File.PathId,
                                  File.Name,
                                  File.JobId,
                                  File.LStat,
                                  File.FileId,
                                  File.FileIndex
   FROM File
   JOIN Job USING (JobId)
   WHERE
      File.JobId IN (%s)
      AND File.PathId = %s
      AND File.Name != ''
      %s
   ORDER BY File.Name,
            Job.StartTime DESC
) AS A
WHERE A.FileIndex > 0
LIMIT %lld
OFFSET %lld
