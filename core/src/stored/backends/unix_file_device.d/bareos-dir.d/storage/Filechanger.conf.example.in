Storage {
  Name = File # Not named "Filechanger" so that it can replace the default single File storage
  Description = "virtual file autochanger with autonumbered device"
  Address = @hostname@                # N.B. Use a fully qualified name here (do not use "localhost" here).
  Password = "@sd_password@"
  Device = FilechangerStorage
  Media Type = File
  # Keep this synchronized with storage->device->vfile Count parameters
  Maximum Concurrent Jobs = 10
}
