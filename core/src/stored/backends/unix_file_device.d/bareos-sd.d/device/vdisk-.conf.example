# The declaration order is important.
Device {
 Name = "vdisk-0000"
 Description = "This device with autoselect=no is reserved for restores and labeling volumes"
 Auto Select = No
 Media Type = "File"
 Device Type = "File"
 Archive device = "/var/lib/bareos/storage"
 Label Media = Yes
 Random Access = Yes
 Automatic Mount = Yes
 Removable Media = No
}

Device {
 Name = "vdisk-"
 Description = "autonumbered disk devices for file backups"
 # Will create multiple devices vdisk-0001 to vdisk-0010
 # Adjust your needs depending of your storage performances.
 Count = 10
 Media Type = "File"
 Device Type = "File"
 Archive device = "/var/lib/bareos/storage"
 Label Media = Yes
 Random Access = Yes
 Automatic Mount = Yes
 Removable Media = No
}
