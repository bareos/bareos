{
  "name": "bareos-webui-vue",
  "version": "1.0.0",
  "description": "Bareos WebUI - Vue/Quasar frontend",
  "type": "module",
  "scripts": {
    "generate:version": "node scripts/generate-bareos-version.mjs",
    "dev": "npm run generate:version && vite",
    "build": "npm run generate:version && env -u VITE_DIRECTOR_PORT -u VITE_DIRECTOR_HOST -u VITE_DIRECTOR_WS_URL vite build",
    "preview": "vite preview",
    "test:unit": "npm run generate:version && vitest run",
    "test:e2e": "npm run generate:version && playwright test"
  },
  "dependencies": {
    "@quasar/extras": "^1.16.0",
    "pinia": "^2.1.0",
    "quasar": "^2.16.0",
    "vue": "^3.4.0",
    "vue-i18n": "^11.3.2",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@quasar/vite-plugin": "^1.7.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "jsdom": "^26.1.0",
    "sass-embedded": "^1.98.0",
    "vite": "^6.2.0",
    "vitest": "^3.2.4"
  }
}
